# ============================================================
# SecScan environment configuration
# Copy this file to .env and fill in real values. NEVER commit .env.
# ============================================================

# Environment: development | staging | production
ENVIRONMENT=production
DEBUG=false

# 64+ char random secret. Generate with: openssl rand -hex 32
SECRET_KEY=replace-me-with-openssl-rand-hex-32-output-must-be-strong

# PostgreSQL
POSTGRES_USER=secscan
POSTGRES_PASSWORD=replace-me-with-a-strong-password
POSTGRES_DB=secscan

# CORS - comma-separated list of allowed frontend origins
CORS_ORIGINS=https://your-app.vercel.app,http://localhost:3000

# Rate limits (per minute)
RATE_LIMIT_PER_MINUTE=60
AUTH_RATE_LIMIT_PER_MINUTE=5

# Scanning
MAX_SCAN_DURATION_SECONDS=600
SCAN_ALLOW_PRIVATE=false

# Public port for backend (behind reverse proxy in prod)
BACKEND_PORT=8000
